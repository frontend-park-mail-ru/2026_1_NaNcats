    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-loader": "^10.1.1",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "dot": "^1.1.3",
    "eslint": "^8.56.0",
    "eslint-plugin-jsdoc": "^48.0.0",
    "html-webpack-plugin": "^5.6.6",
    "jsdoc": "^4.0.2",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
