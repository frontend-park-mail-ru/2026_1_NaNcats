{
  "name": "2026_1_nancats",
  "version": "1.0.0",
  "description": "Frontend project with JSDoc and ESLint",
  "main": "server.js",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "npm run type-check && webpack --mode production",
    "server": "node server.js",
    "lint": "eslint src/**/*.{ts,tsx,js}",
    "lint:fix": "eslint src/**/*.{ts,tsx,js} --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,scss,css,json,html,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,scss,css,json,html,md}\"",
    "doc": "jsdoc -c jsdoc.json",
    "type-check": "tsc --noEmit && tsc -p src/sw.tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-react-jsx": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "babel-loader": "^10.1.1",
    "better-docs": "2.7.3",
    "core-js": "^3.49.0",
    "css-loader": "^7.1.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "^48.0.0",
    "html-webpack-plugin": "^5.6.6",
    "jsdoc": "^4.0.2",
    "prettier": "3.8.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
